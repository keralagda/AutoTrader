generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TestModel3 {
  id    String   @id @default(cuid())
  key   String   @unique
  value String
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  password         String
  phone            String?
  walletAddress    String?
  role             String    @default("user") // "user" or "admin"
  referralCode     String    @unique
  referredById     String?
  referredBy       User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals        User[]    @relation("Referrals")
  tradingBalance   Float     @default(0) // Wallet 1: For Trading Plans (deposits & earnings stay here)
  withdrawalBalance Float    @default(0) // Wallet 2: For Withdrawals (user transfers from trading to withdrawal)
  totalEarnings    Float     @default(0)
  totalDeposited   Float     @default(0)
  isActive         Boolean   @default(true)
  isEmailVerified  Boolean   @default(false)
  emailVerificationToken String?
  isFake           Boolean   @default(false)
  fakeAvatar       String?
  kycStatus        String    @default("none") // "none", "pending", "approved", "rejected"
  twoFactorSecret  String?
  twoFactorEnabled Boolean   @default(false)
  riskCategory     String    @default("medium") // "low", "medium", "high" - determines earning variation
  customWinMin     Float?    // Admin override: minimum daily % for this user (null = use category default)
  customWinMax     Float?    // Admin override: maximum daily % for this user (null = use category default)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  deposits            Deposit[]
  earnings            Earning[]
  withdrawals         Withdrawal[]
  leaderboardEntries  LeaderboardEntry[]
  userChallenges      UserChallenge[]
  payments            Payment[]
  userStats           UserStats?
  userBadges          UserBadge[]
  dailyCheckIns       DailyCheckIn[]
  messages            Message[]
  kycVerification     KycVerification?
  supportTickets      SupportTicket[]
  notifications       Notification[]
  p2pSent             P2PTransfer[]    @relation("P2PSent")
  p2pReceived         P2PTransfer[]    @relation("P2PReceived")
  loginHistory        LoginHistory[]
  transactionLogs     TransactionLog[]
  binaryTreeAuditLogs BinaryTreeAuditLog[] @relation("BinaryTreeAuditLogs")

  telegramChatId        String?   @unique
  telegramVerificationCode String?
  transactionPin        String?
  usdcBscAddress        String?   @unique
  usdcTronAddress       String?   @unique
  usdcDerivationIndex   Int       @default(0)
  isAffiliate           Boolean   @default(false)
  affiliateClicks       Int       @default(0)
  customPromoHeadline   String?
  customPromoLogo       String?
  depositWallets        String?
  withdrawWallets       String?

  binaryTreePosition               String    @default("")
  binaryTreeParentId               String?
  binaryTreeLeftChildId            String?
  binaryTreeRightChildId           String?
  binaryTreeLeftVolume             Float     @default(0)
  binaryTreeRightVolume            Float     @default(0)
  binaryTreeLeftVolumeCarryForward Float     @default(0)
  binaryTreeRightVolumeCarryForward Float    @default(0)

  personalVolume Float @default(0)
  businessVolume Float @default(0)
  teamVolume     Float @default(0)
  mlmRank        String @default("Member")
  mlmLevel       Int    @default(0)

  autoUpgradeEnabled      Boolean   @default(false)
  autoUpgradePercent      Float     @default(5.0)
  autoUpgradeAccumulated  Float     @default(0.0)
  autoUpgradeTargetPlanId String?
  autoUpgradeTargetPlan   Plan?     @relation("AutoUpgradeTargetPlan", fields: [autoUpgradeTargetPlanId], references: [id])
  autoInvestmentEnabled   Boolean   @default(false)

  affiliateApplications AffiliateApplication[]
}

model Plan {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  entryFee              Float
  minDeposit            Float
  maxDeposit            Float
  dailyEarningPercent   Float
  maxEarningLimit       Float
  maxEarningMultiplier  Float    @default(2.0)

  // Time-based Plan Configuration
  returnType            String   @default("daily") // "hourly", "daily", "weekly", "monthly", "after_end"
  returnPeriodHours     Int      @default(24)      // How often profit is credited (1=hourly, 24=daily, 168=weekly)
  totalReturnPercent    Float    @default(0)       // Total % return over plan lifetime (0 = use dailyEarningPercent * duration)
  durationDays          Int      @default(0)       // Plan duration in days (0 = unlimited until maxEarningLimit)
  capitalReturn         String   @default("included") // "included" (principal in profit), "end" (return at end), "none" (no return)
  repeatCount           Int      @default(0)       // Number of profit payouts (0 = unlimited until max)

  // Advanced Plan Builder Fields
  stackingEnabled       Boolean  @default(false)
  maxStacks             Int      @default(1)
  stackingBonusPercent  Float    @default(0)
  lockPeriodDays        Int      @default(0)
  autoCompound          Boolean  @default(false)
  earlyExitPenalty      Float    @default(0)

  // Distribution Rules
  accountHolderPercent  Float    @default(50)
  tradeProfitSharePercent Float  @default(30)
  rewardsOffersPercent  Float    @default(15)
  platformFeePercent    Float    @default(5)

  // Subscription Distribution
  isSubscriptionDistributionEnabled Boolean @default(false)
  subscriptionReferralPercent Float @default(80)
  subscriptionRewardsPercent  Float @default(15)
  subscriptionPlatformPercent Float @default(5)

  // Plan Logic Description
  earningMechanism      String?
  withdrawalRule        String?
  stackingRule          String?

  // Risk Level Configuration
  riskLevels            String    @default("low,medium,high") // Comma-separated: which risk levels this plan supports
  lowRiskMin            Float     @default(0.5)  // Min daily % for low risk
  lowRiskMax            Float     @default(2.0)  // Max daily % for low risk
  mediumRiskMin         Float     @default(2.0)  // Min daily % for medium risk
  mediumRiskMax         Float     @default(5.0)  // Max daily % for medium risk
  highRiskMin           Float     @default(5.0)  // Min daily % for high risk
  highRiskMax           Float     @default(15.0) // Max daily % for high risk
  rotateWinPercent      Boolean   @default(true) // Rotate win % with each stack
  rotationIncrement     Float     @default(0.5)  // % increment per stack rotation

  isActive              Boolean  @default(true)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Plan A Customization & Capping Fields
  depositMultipleOf          Float    @default(1.0)
  strictMultiples            Boolean  @default(true)
  dailyEarningCapPercent     Float    @default(0.0)
  cappingType                String   @default("percentage")
  cappingAppliesTo           String   @default("all")
  registrationReferralLevels Int      @default(7)

  // Binary MLM Configuration
  isBinaryMlmEnabled          Boolean   @default(false)
  binaryPairingBonusPercent   Float     @default(10.0)
  binaryPairingBonusType      String    @default("percent")
  binaryPairingBonusFixed     Float     @default(0.0)
  binaryMatchingType          String    @default("weaker_leg")
  binaryDailyPairingCap       Int       @default(0)
  binaryWeeklyPairingCap      Int       @default(0)
  binaryCarryForward          Boolean   @default(true)
  binarySpilloverPlacement    String    @default("balanced")
  binaryDepthLimit            Int       @default(0)
  binaryFlushBonusEnabled     Boolean   @default(false)
  binaryFlushBonusPercent     Float     @default(5.0)
  binaryFlushBonusThreshold   Int       @default(200)
  binaryCycleEnabled          Boolean   @default(false)
  binaryCycleRatio            String    @default("1:1")
  binaryCycleBonusPercent     Float     @default(5.0)
  binaryCycleBonusType        String    @default("percent")
  binaryCycleBonusFixed       Float     @default(0.0)

  binaryPvRatio               Float     @default(1.0)
  binaryBvRatio               Float     @default(1.0)
  binaryTvRatio               Float     @default(1.0)
  mlmRewardsConfig            String?
  mlmPoolsConfig              String?

  // Advanced Profit & Loss Configuration
  minLossPercent             Float    @default(0.1)
  maxLossPercent             Float    @default(5.0)
  allowNegativeBalance       Boolean  @default(false)
  maxConsecutiveLossDays     Int      @default(3)
  drawdownLimit              Float    @default(10.0)
  profitTarget               Float    @default(20.0)
  hedgingRatio               Float    @default(0.0)
  lossLimitAction            String   @default("pause")
  pnlLogicDescription        String?

  // Extra Fund-Sharing Percentages
  charityDonationPercent     Float    @default(0)
  insuranceReservePercent    Float    @default(0)
  developerFundPercent       Float    @default(0)
  liquidityPoolPercent       Float    @default(0)

  // Scheduling & Limits
  profitDays          String   @default("mon,tue,wed,thu,fri")
  profitHours         String?
  holidayPauses       String?
  gracePeriodDays     Int      @default(0)
  autoReinvest        Boolean  @default(false)
  reinvestBonus       Float    @default(2)
  minReinvestAmount     Float    @default(0)
  reinvestLockPeriod    Int      @default(0)
  customReferralPct   Float?
  volatilityMode      String   @default("moderate")
  lossDayChance       Float    @default(0)
  bonusDayChance      Float    @default(5)
  minVipTier          String   @default("Bronze")
  spotsLimit          Int      @default(0)
  planBadge           String?
  teamRequirement     Int      @default(0)
  countdownEnd        DateTime?

  autoUpgradeTargetUsers User[]  @relation("AutoUpgradeTargetPlan")
  deposits Deposit[]
  referralRules       PlanReferralRule[]
  conditionalLogics   PlanConditionalLogic[]
  pnlLogs             PlanPnLLog[]
  insuranceVault      PlanInsuranceVault?
  pairingRules        PlanPairingRule[]

  isLeadershipEligible         Boolean  @default(true)

  // Staking Configurations
  stakingEnabled               Boolean  @default(false)
  stakingMinDays              Int      @default(30)
  stakingBonusPercent          Float    @default(0.0)
  stakingEarlyWithdrawalPenalty Float    @default(10.0)
  showPairingRulesInPlanDetails Boolean  @default(false)
}

// Custom Level-by-Level Referral Payouts per Plan
model PlanReferralRule {
  id                 String   @id @default(cuid())
  planId             String
  level              Int      // Level 1, 2, 3, etc.
  commission         Float    // Percentage commission for this level
  amount             Float    @default(0.0)
  type               String   @default("registration") // "registration", "profit", or "deposit"
  minSponsorDeposit  Float    @default(0.0)
  minDirectReferrals Int      @default(0)
  targetWallet       String   @default("trading") // "trading" or "withdrawal"
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  plan       Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, level, type])
}

// Plan-specific Conditional Rules Engine
model PlanConditionalLogic {
  id            String   @id @default(cuid())
  planId        String
  enabled       Boolean  @default(true)
  priority      Int      @default(1)
  conditionType String   // "daily_yield", "consecutive_loss_days", "active_deposits", "day_of_week", "spots_filled"
  operator      String   // ">", "<", "==", "contains"
  value         String   // condition threshold
  actionType    String   // "adjust_yield", "adjust_multiplier", "pause_referrals", "adjust_splits", "disable_plan"
  actionValue   String   // target value
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  plan          Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
}

// Daily Payout Logs for Analytics & Transparency
model PlanPnLLog {
  id          String   @id @default(cuid())
  planId      String
  yield       Float    // Actual percentage yield credited/deducted (+/-)
  isLoss      Boolean  @default(false)
  distributed Float    // Total USD/USDC distributed in this run
  createdAt   DateTime @default(now())

  plan        Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
}

// Risk Protection & Capital Reserve Vault per Plan
model PlanInsuranceVault {
  id         String   @id @default(cuid())
  planId     String   @unique
  balance    Float    @default(0)
  updatedAt  DateTime @updatedAt

  plan       Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model Deposit {
  id            String   @id @default(cuid())
  userId        String
  planId        String
  amount        Float
  status        String   @default("active") // "active", "completed", "cancelled", "locked", "ended"
  earnedSoFar   Float    @default(0)
  stackIndex    Int      @default(1)
  riskLevel     String   @default("medium") // "low", "medium", "high" - chosen at investment time
  lockedUntil   DateTime?
  nextProfitAt  DateTime? // When the next scheduled profit will be credited
  profitCount   Int      @default(0) // How many times profit has been paid out
  capitalReturned Boolean @default(false) // Whether principal has been returned
  endsAt        DateTime? // When this deposit's plan duration expires
  lastProfitAt  DateTime? // When profit was last credited
  isReinvested  Boolean  @default(false) // Whether this was created via reinvest
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user              User                @relation(fields: [userId], references: [id])
  plan              Plan                @relation(fields: [planId], references: [id])
  earnings          Earning[]
  profitDistributions ProfitDistribution[]

  // Staking Properties
  isStaked          Boolean   @default(false)
  stakedUntil       DateTime?
  stakingBonusRate  Float     @default(0.0)
}

// ─── Transaction Log (Complete Ledger) ─────────────────────────────

model TransactionLog {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "deposit", "withdrawal", "investment", "profit", "referral", "transfer", "reinvest", "capital_return", "fee", "bonus"
  amount      Float
  balanceBefore Float  @default(0)
  balanceAfter  Float  @default(0)
  wallet      String   @default("trading") // "trading" or "withdrawal"
  description String?
  referenceId String?  // ID of related deposit/withdrawal/earning
  status      String   @default("completed") // "completed", "pending", "failed"
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Earning {
  id        String   @id @default(cuid())
  userId    String
  depositId String?
  amount    Float
  type      String   // "referral", "profit_share", "bonus", "daily", "stacking_bonus", "subtract"
  level     Int?
  walletTarget String @default("trading") // "trading" or "withdrawal" - which wallet receives this
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  deposit Deposit? @relation(fields: [depositId], references: [id])
}

model Withdrawal {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  walletAddress String
  status        String   @default("pending") // "pending", "approved", "rejected", "completed"
  txHash        String?
  paymentMethod String?  // "crypto_usdc", "crypto_btc", "crypto_eth", "upi", "bank_transfer", "razorpay"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ProfitDistribution {
  id         String   @id @default(cuid())
  depositId  String
  amount     Float
  riskMode   String   // "safe", "medium", "risk"
  dayOfWeek  String   // "monday", "tuesday", etc.
  operation  String   @default("add") // "add" or "subtract"
  reason     String?  // Admin's reason for this operation
  createdAt  DateTime @default(now())

  deposit Deposit @relation(fields: [depositId], references: [id])
}

model LeaderboardEntry {
  id            String   @id @default(cuid())
  userId        String
  totalEarnings Float
  rank          Int
  period        String   // "daily", "weekly", "monthly", "all_time"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Challenge {
  id              String   @id @default(cuid())
  title           String
  description     String
  category        String   @default("milestone") // "daily", "weekly", "milestone", "special", "streak", "referral", "deposit"
  challengeType   String   @default("target")     // "target" (reach a number), "streak" (consecutive days), "action" (do something once)
  targetValue     Float    @default(1)            // The goal number (e.g. deposit $500, refer 3 friends, 7-day streak)
  reward          Float    @default(0)            // USDC reward amount
  xpReward        Int      @default(0)            // XP points awarded
  badgeIcon       String   @default("🎯")         // Emoji icon for the challenge
  difficulty      String   @default("easy")       // "easy", "medium", "hard", "elite"
  colorTheme      String   @default("emerald")    // Color theme: "emerald", "amber", "cyan", "rose", "violet"
  streakBased     Boolean  @default(false)         // Is this a streak-based challenge?
  requireStreakDays Int    @default(0)             // How many consecutive days needed for streak challenges
  bonusMultiplier Float    @default(1)             // Reward multiplier (e.g. 2x for special events)
  isRecurring     Boolean  @default(false)         // Does this challenge reset periodically?
  recurrencePeriod String  @default("none")        // "none", "daily", "weekly", "monthly"
  startDate       DateTime @default(now())
  endDate         DateTime?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userChallenges UserChallenge[]
}

model UserChallenge {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  progress    Float    @default(0)
  completed   Boolean  @default(false)
  claimed     Boolean  @default(false)
  startedAt   DateTime @default(now())
  completedAt DateTime?
  streakCount Int      @default(0)    // Current streak for streak-based challenges
  lastProgressAt DateTime?            // When was progress last updated (for streak tracking)

  user      User      @relation(fields: [userId], references: [id])
  challenge Challenge @relation(fields: [challengeId], references: [id])
}

model UserStats {
  id              String  @id @default(cuid())
  userId          String  @unique
  xp              Int     @default(0)
  level           Int     @default(1)
  currentStreak   Int     @default(0)     // Current daily check-in streak
  longestStreak   Int     @default(0)     // Longest daily check-in streak ever
  lastCheckIn     DateTime?               // Last daily check-in date
  totalCheckIns   Int     @default(0)     // Total number of check-ins
  challengesCompleted Int @default(0)     // Total challenges completed
  challengesClaimed Int   @default(0)     // Total rewards claimed
  totalXpEarned   Int     @default(0)     // Total XP ever earned
  totalUsdcRewards Float  @default(0)     // Total USDC from challenge rewards
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Badge {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String            // Emoji icon
  category    String   @default("achievement") // "achievement", "milestone", "streak", "social", "special"
  rarity      String   @default("common")      // "common", "uncommon", "rare", "epic", "legendary"
  xpRequired  Int      @default(0)             // XP needed to auto-unlock (0 = challenge-only)
  condition   String            // Plain English condition to earn this badge
  colorTheme  String   @default("emerald")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  userBadges UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  badge Badge  @relation(fields: [badgeId], references: [id])
}

model DailyCheckIn {
  id        String   @id @default(cuid())
  userId    String
  checkDate DateTime // The date of check-in (date only, no time)
  xpEarned  Int      @default(0)
  bonusEarned Float  @default(0)  // USDC bonus if applicable
  streakDay Int      @default(1)  // Which day of the streak this was

  user User @relation(fields: [userId], references: [id])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  method        String   // "crypto_usdc", "crypto_btc", "crypto_eth", "upi", "bank_transfer", "razorpay"
  status        String   @default("pending") // "pending", "confirmed", "failed", "refunded"
  txHash        String?  // For crypto payments
  upiRef        String?  // For UPI payments
  gatewayRef    String?  // For Razorpay/other gateway reference
  planId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model PaymentGateway {
  id          String   @id @default(cuid())
  name        String   // e.g. "USDC (Polygon)", "UPI", "Razorpay"
  type        String   // "crypto" or "indian" or "manual"
  network     String?  // e.g. "polygon", "ethereum", "bitcoin"
  address     String?  // Wallet address for crypto or receiving address for manual
  apiKey      String?  // API key for gateways
  apiSecret   String?  // API secret for gateways
  webhookUrl  String?  // Webhook URL for payment confirmations
  minAmount   Float    @default(10)
  maxAmount   Float    @default(100000)
  feePercent  Float    @default(0)
  isActive    Boolean  @default(false)
  sortOrder   Int      @default(0)
  qrImage     String?  // Uploaded QR code image url/path
  instructions String? // Custom instructions for payment
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Message Centre ────────────────────────────────────────────────

model Message {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  body        String
  type        String   @default("email") // "email", "notification", "system"
  direction   String   @default("received") // "sent", "received"
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── News ──────────────────────────────────────────────────────────

model News {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String   @default("general") // "general", "update", "promotion", "alert"
  isPublished Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Fake Notification Toast (Admin-managed) ───────────────────────

model FakeNotification {
  id          String   @id @default(cuid())
  userName    String   // Fake user name
  planName    String   // Plan they "joined"
  amount      Float    @default(0) // Amount invested
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

// ─── Fake Notification Settings ────────────────────────────────────

model FakeNotificationSettings {
  id              String  @id @default(cuid())
  isEnabled       Boolean @default(true)
  minDelaySeconds Int     @default(5)
  maxDelaySeconds Int     @default(15)
}

// ─── KYC Verification ──────────────────────────────────────────────

model KycVerification {
  id            String   @id @default(cuid())
  userId        String   @unique
  documentType  String   // "aadhaar", "pan", "passport", "driving_license"
  documentNumber String?
  documentUrl   String?  // File path/URL
  selfieUrl     String?
  status        String   @default("pending") // "pending", "approved", "rejected"
  rejectionReason String?
  submittedAt   DateTime @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?

  user User @relation(fields: [userId], references: [id])
}

// ─── Support Tickets ───────────────────────────────────────────────

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  description String
  category    String   @default("general") // "general", "withdrawal", "deposit", "technical", "account"
  priority    String   @default("medium") // "low", "medium", "high", "urgent"
  status      String   @default("open") // "open", "in_progress", "resolved", "closed"
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id])
  replies TicketReply[]
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String   // Who replied (user or admin)
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id])
}

// ─── Notifications (In-App) ───────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // "info", "success", "warning", "earning", "withdrawal", "referral"
  isRead    Boolean  @default(false)
  link      String?  // Optional link to navigate to
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── P2P Transfers ─────────────────────────────────────────────────

model P2PTransfer {
  id           String   @id @default(cuid())
  senderId     String
  receiverId   String
  amount       Float
  note         String?
  status       String   @default("completed") // "completed", "reversed"
  createdAt    DateTime @default(now())

  sender   User @relation("P2PSent", fields: [senderId], references: [id])
  receiver User @relation("P2PReceived", fields: [receiverId], references: [id])
}

// ─── Login History ─────────────────────────────────────────────────

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  device    String?  // "desktop", "mobile", "tablet"
  location  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── Activity Log (Admin Audit) ────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?  // Who performed the action
  action    String   // "withdrawal_approved", "profit_added", "user_banned", etc.
  details   String?  // JSON details
  ipAddress String?
  createdAt DateTime @default(now())
}

// ─── Testimonials (Landing Page) ───────────────────────────────────

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  avatar    String?  // Emoji or URL
  role      String?  // "Trader", "Investor", etc.
  content   String
  rating    Int      @default(5) // 1-5 stars
  earnings  String?  // "$5,000 earned" display text
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// ─── Promotions / Countdown Timers ─────────────────────────────────

model Promotion {
  id          String   @id @default(cuid())
  title       String
  description String
  bannerText  String?  // Short text for banner display
  type        String   @default("general") // "general", "referral_bonus", "deposit_bonus", "limited_time"
  multiplier  Float    @default(1) // e.g., 2 for "2x referral bonus"
  startDate   DateTime @default(now())
  endDate     DateTime
  isActive    Boolean  @default(true)
  showOnLanding Boolean @default(true)
  showOnDashboard Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Landing Page CMS ──────────────────────────────────────────────

model LandingSection {
  id          String   @id @default(cuid())
  sectionKey  String   @unique // "hero", "stats", "plans", "calculator", "distribution", "referral", "testimonials", "footer"
  title       String?
  subtitle    String?
  content     String?  // JSON blob for complex content
  isVisible   Boolean  @default(true)
  sortOrder   Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model MediaUpload {
  id          String   @id @default(cuid())
  fileName    String
  fileType    String   // "image", "video", "document"
  fileSize    Int      @default(0)
  url         String   // Stored path or base64 data URL
  alt         String?
  uploadedBy  String?
  createdAt   DateTime @default(now())
}

model AffiliateApplication {
  id            String   @id @default(cuid())
  userId        String
  trafficSource String
  audienceSize  Int
  telegram      String
  status        String   @default("pending") // "pending", "approved", "rejected"
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PromoBanner {
  id          String   @id @default(cuid())
  title       String
  imageUrl    String
  size        String   // e.g. "728x90", "300x250", "1080x1080"
  downloadUrl String
  createdAt   DateTime @default(now())
}

model BinaryTreeAuditLog {
  id            String   @id @default(cuid())
  userId        String
  actionType    String   // PLACE, VOLUME_UPDATE, BALANCE_ADJUST, etc.
  actionDetails Json     // Specifics of what changed
  performedBy   String?  // Admin/System/User
  performedAt   DateTime @default(now())

  user          User     @relation("BinaryTreeAuditLogs", fields: [userId], references: [id])
}

model TestModel2 {
  id    String   @id @default(cuid())
  key   String   @unique
  value String
}

model CustomPostType {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  posts       CustomPost[]
  taxonomies  CustomTaxonomy[]
}

model CustomTaxonomy {
  id         String   @id @default(cuid())
  postTypeId String
  slug       String   
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  postType   CustomPostType @relation(fields: [postTypeId], references: [id], onDelete: Cascade)
  terms      CustomTaxonomyTerm[]
  
  @@unique([postTypeId, slug])
}

model CustomTaxonomyTerm {
  id         String   @id @default(cuid())
  taxonomyId String
  name       String
  slug       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  taxonomy   CustomTaxonomy @relation(fields: [taxonomyId], references: [id], onDelete: Cascade)
  posts      CustomPostTaxonomyTerm[]
  
  @@unique([taxonomyId, slug])
}

model CustomFieldGroup {
  id               String   @id @default(cuid())
  name             String
  rules            String   // JSON string representing target rules (e.g. postType === "signals", or user === "any")
  conditionalLogic String?  // JSON string for conditional group visibility
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  fields           CustomFieldDefinition[]
}

model CustomFieldDefinition {
  id               String   @id @default(cuid())
  groupId          String
  key              String
  label            String
  type             String   // "text", "number", "select", "date", "image", "boolean", "relation"
  options          String?  // JSON or comma-separated values for select type
  placeholder      String?
  required         Boolean  @default(false)
  conditionalLogic String?  // JSON string representing conditional display logic
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  group            CustomFieldGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  @@unique([groupId, key])
}

model CustomPost {
  id         String   @id @default(cuid())
  postTypeId String
  title      String
  slug       String
  content    String?  @db.Text
  status     String   @default("draft") // "draft", "published"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  postType   CustomPostType @relation(fields: [postTypeId], references: [id], onDelete: Cascade)
  taxonomies CustomPostTaxonomyTerm[]
  
  @@unique([postTypeId, slug])
}

model CustomFieldValue {
  id         String   @id @default(cuid())
  fieldKey   String
  value      String   @db.Text // stores JSON or plain string representation
  entityType String   // "post", "user", "plan", "deposit", etc.
  entityId   String   // ID of target entity
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId, fieldKey])
}

model CustomPostTaxonomyTerm {
  id        String   @id @default(cuid())
  postId    String
  termId    String
  createdAt DateTime @default(now())

  post      CustomPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  term      CustomTaxonomyTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([postId, termId])
}

model PlanPairingRule {
  id                 String   @id @default(cuid())
  planId             String
  levelRange         String   // "1", "2", "3-5", "6+" etc.
  ratio              String   @default("100:100") // "100:100", "100:200", "200:100" etc.
  bonusType          String   @default("percent") // "percent" or "fixed"
  bonusValue         Float    @default(10.0)
  minDirectLeft      Int      @default(0)
  minDirectRight     Int      @default(0)
  minPersonalIv      Float    @default(0.0)
  minTeamTv          Float    @default(0.0)
  perks              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  plan               Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
}

