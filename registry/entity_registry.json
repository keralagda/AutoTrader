        "maxDeposit": "Float",
        "entryFee": "Float",
        "lockPeriodDays": "Int",
        "isActive": "Boolean",
        "isBinaryMlmEnabled": "Boolean",
        "isLeadershipEligible": "Boolean",
        "mlmRewardsConfig": "String (JSON)",
        "mlmPoolsConfig": "String (JSON)",
        "stakingEnabled": "Boolean",
        "stakingMinDays": "Int",
        "stakingBonusPercent": "Float",
