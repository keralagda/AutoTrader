{
  "registry": "Schema Registry",
  "version": "1.0.0",
  "description": "JSON Schemas for JSON fields and Settings values stored in the database",
  "schemas": {
    "logic_builder_config": {
      "type": "object",
      "properties": {
        "variables": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "type": { "type": "string", "enum": ["slider", "range", "number"] },
              "value": { "type": "number" },
              "min": { "type": "number" },
              "max": { "type": "number" },
              "step": { "type": "number" },
              "enabled": { "type": "boolean" }
            },
            "required": ["id", "name", "type", "value"]
          }
        },
        "profitRules": { "type": "array" },
        "calculatorRules": { "type": "array" },
        "stackingRules": { "type": "array" },
        "patterns": { "type": "array" },
        "depositRules": { "type": "array" },
        "riskRules": { "type": "array" }
      }
    },
    "nova_points_config": {
      "type": "object",
      "properties": {
        "conversionRate": { "type": "integer" },
        "xpPerLevel": { "type": "integer" },
        "checkin": {
          "type": "object",
          "properties": {
            "baseNP": { "type": "integer" },
            "streak3NP": { "type": "integer" },
            "streak5NP": { "type": "integer" },
            "streak7NP": { "type": "integer" }
          }
        },
        "storeItems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "cost": { "type": "integer" },
              "description": { "type": "string" },
              "type": { "type": "string" },
              "enabled": { "type": "boolean" }
            }
          }
        },
        "luckySpinPrizes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "amount": { "type": "number" },
              "weight": { "type": "integer" }
            }
          }
        }
      }
    }
  }
}
